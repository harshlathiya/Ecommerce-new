# API
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce
JWT_SECRET=replace-with-long-random-secret
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Payments (optional — stubs used if empty)
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Redis (optional)
REDIS_URL=

# Seed script (optional)
SEED_SUPER_EMAIL=admin@example.com
SEED_SUPER_PASSWORD=ChangeMe123!
SEED_STORE_ADMIN_EMAIL=store@example.com
SEED_STORE_ADMIN_PASSWORD=ChangeMe123!

# Vite apps — leave empty to use same-origin /api proxy in dev
VITE_API_URL=

# Storefront default tenant (optional)
VITE_DEFAULT_STORE_SLUG=demo-store
